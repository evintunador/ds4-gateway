#!/usr/bin/env python3
"""Stdlib stand-in for ds4-server: accepts the same CLI shape the gateway
spawns, serves the endpoints the gateway health-checks and proxies, and
reports its own argv so tests can tell resident from --ssd-streaming
instances. FAKE_DS4_STARTUP_DELAY (seconds) simulates slow model loading."""

import json
import os
import sys
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

ARGV = sys.argv[1:]


def flag_value(name, default=None):
    return ARGV[ARGV.index(name) + 1] if name in ARGV else default


PORT = int(flag_value("--port", 8000))
HOST = flag_value("--host", "127.0.0.1")


class H(BaseHTTPRequestHandler):
    def _send(self, obj, status=200):
        body = json.dumps(obj).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path == "/v1/models":
            self._send({"object": "list",
                        "data": [{"id": "deepseek-v4-flash", "object": "model"}],
                        "fake_args": ARGV, "port": PORT,
                        "streaming_mode": "--ssd-streaming" in ARGV})
        else:
            self._send({"error": "not found"}, 404)

    def do_POST(self):
        self.rfile.read(int(self.headers.get("Content-Length", 0)))
        if self.path == "/v1/chat/completions":
            time.sleep(0.05)
            self._send({"choices": [{"message": {
                "role": "assistant",
                "content": f"fake reply from :{PORT}"}}],
                "served_by_port": PORT,
                "streaming_mode": "--ssd-streaming" in ARGV})
        else:
            self._send({"error": "not found"}, 404)

    def log_message(self, *a):
        pass


if __name__ == "__main__":
    time.sleep(float(os.environ.get("FAKE_DS4_STARTUP_DELAY", 0)))
    ThreadingHTTPServer((HOST, PORT), H).serve_forever()
