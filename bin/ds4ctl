#!/usr/bin/env python3
"""Control the ds4 gateway.

  ds4ctl status                 show power/gate/backend/queue state
  ds4ctl on                     re-enable and reload the model
  ds4ctl off                    stop the model server, free the RAM
  ds4ctl off --for 2h           ...and auto-relaunch after 2h (also: 90m, 1h30m, 45s)
  ds4ctl swap-model             red/yellow model swap (edit config.toml first)
  ds4ctl deploy [...]           blue/green gateway deploy (tools/deploy.py)
  ds4ctl promote                make the live release the boot version
  ds4ctl install-daemon         print (not run) the LaunchDaemon install commands
  ds4ctl stats [--days 7]       aggregate usage: peak hours, tokens, per-user
  ds4ctl weights                show fairness weights
  ds4ctl weights LOGIN N        set a user's weight live (persists); --clear resets
  ds4ctl bench [...]            runtime benchmark (tools/bench.py)

Talks to the gateway admin API on localhost. Uses port 9001 (blue) by
default, falling back to 9002 (green); override with --port or DS4CTL_PORT.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
import time
import urllib.error
import urllib.request

PORTS = [9001, 9002]


def parse_duration(s: str) -> float:
    m = re.fullmatch(r"(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s)?", s.strip())
    if not m or not any(m.groups()):
        sys.exit(f"ds4ctl: cannot parse duration '{s}' (examples: 2h, 90m, 1h30m, 45s)")
    h, mi, se = (int(g) if g else 0 for g in m.groups())
    return h * 3600 + mi * 60 + se


def call(port: int, method: str, path: str, payload: dict | None = None):
    req = urllib.request.Request(
        f"http://127.0.0.1:{port}{path}", method=method,
        data=json.dumps(payload).encode() if payload is not None else None,
        headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=30) as r:
        return json.loads(r.read())


def find_port(preferred: int | None):
    candidates = [preferred] if preferred else PORTS
    for port in candidates:
        try:
            return port, call(port, "GET", "/admin/status")
        except (urllib.error.URLError, OSError):
            continue
    sys.exit(f"ds4ctl: no gateway responding on port(s) {candidates}")


def print_status(s: dict):
    p, b = s["power"], s["backend"]
    gate = "OPEN" if p["serving_allowed"] else "CLOSED"
    print(f"gateway    {s['color']}  up {s['uptime_s']:.0f}s  owner {s['owner']}")
    print(f"power      {'AC' if p['on_ac'] else 'battery'} {p['percent']}%  "
          f"remote gate {gate} (needs AC + >={p['min_battery_percent']}%)"
          + ("  [OVERRIDE ACTIVE]" if p["override_active"] else ""))
    line = f"backend    {b['state']}"
    if b["pid"]:
        line += f"  pid {b['pid']}"
    if b["disabled"]:
        line += "  DISABLED"
        if b["disabled_until"]:
            mins = (b["disabled_until"] - time.time()) / 60
            line += f" (auto-on in {mins:.0f}m)"
    print(line + f"  -> {b['base_url']}")
    if b.get("swap_state"):
        print(f"swap       {b['swap_state']}")
    sched = s["scheduler"]
    queued = ", ".join(f"{u}:{n}" for u, n in sched["queued"].items()) or "empty"
    print(f"scheduler  busy: {sched['busy_user'] or 'idle'}  queued: {queued}")


def print_stats(status, days):
    path = status.get("usage_log")
    if not path:
        sys.exit("gateway does not report a usage log (pre-3.5 release?)")
    since = time.time() - days * 86400
    events = []
    for p in (path + ".1", path):
        try:
            with open(p) as f:
                for line in f:
                    try:
                        e = json.loads(line)
                    except ValueError:
                        continue
                    if e.get("ts", 0) >= since:
                        events.append(e)
        except OSError:
            continue
    if not events:
        print(f"no usage recorded in the last {days:g} days")
        return

    users = {}
    hours = [[0, 0] for _ in range(24)]  # per local hour-of-day: [reqs, completion tokens]
    for e in events:
        u = users.setdefault(e.get("user", "?"),
                             {"reqs": 0, "ok": 0, "gated": 0, "throttled": 0,
                              "pt": 0, "ct": 0, "est": False})
        u["reqs"] += 1
        st = e.get("status", 0)
        if 200 <= st < 300:
            u["ok"] += 1
        elif e.get("code") in ("battery_gated", "manually_disabled"):
            u["gated"] += 1
        elif st == 429:
            u["throttled"] += 1
        u["pt"] += e.get("prompt_tokens") or 0
        u["ct"] += e.get("completion_tokens") or 0
        u["est"] = u["est"] or e.get("estimated", False)
        h = time.localtime(e["ts"]).tm_hour
        hours[h][0] += 1
        hours[h][1] += e.get("completion_tokens") or 0

    print(f"== usage, last {days:g} days ({len(events)} requests) ==")
    print(f"{'user':<28} {'reqs':>6} {'ok':>6} {'gated':>6} {'429':>5} "
          f"{'prompt tok':>11} {'compl tok':>10}")
    for login, u in sorted(users.items(), key=lambda kv: -kv[1]["reqs"]):
        est = "~" if u["est"] else " "
        print(f"{login:<28} {u['reqs']:>6} {u['ok']:>6} {u['gated']:>6} "
              f"{u['throttled']:>5} {u['pt']:>11} {est}{u['ct']:>9}")
    print("\nby local hour of day (# = requests):")
    peak = max(r for r, _ in hours) or 1
    for h in range(24):
        r, ct = hours[h]
        bar = "#" * round(20 * r / peak)
        tok = f"  {ct} tok" if ct else ""
        print(f"  {h:02d}  {bar:<20} {r}{tok}" if r else f"  {h:02d}")
    top = sorted(range(24), key=lambda h: -hours[h][0])[:3]
    print("peak hours: " + ", ".join(f"{h:02d}:00 ({hours[h][0]} reqs)"
                                     for h in top if hours[h][0]))
    print("('~' = streamed responses; completion tokens estimated from chunk counts)")


def main():
    ap = argparse.ArgumentParser(prog="ds4ctl")
    ap.add_argument("--port", type=int, default=int(os.environ.get("DS4CTL_PORT", 0)) or None)
    sub = ap.add_subparsers(dest="cmd", required=True)
    sub.add_parser("status")
    sub.add_parser("on")
    off = sub.add_parser("off")
    off.add_argument("--for", dest="duration", default=None,
                     help="auto re-enable after this long (2h, 90m, 1h30m)")
    sub.add_parser("swap-model")
    dep = sub.add_parser("deploy")
    dep.add_argument("extra", nargs="*", help="passed through to tools/deploy.py")
    sub.add_parser("promote")
    sub.add_parser("install-daemon")
    stats = sub.add_parser("stats")
    stats.add_argument("--days", type=float, default=7)
    wts = sub.add_parser("weights")
    wts.add_argument("login", nargs="?")
    wts.add_argument("weight", nargs="?", type=float)
    wts.add_argument("--clear", action="store_true")
    bench = sub.add_parser("bench")
    bench.add_argument("extra", nargs="*", help="passed through to tools/bench.py")
    args = ap.parse_args()

    repo = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
    if args.cmd == "bench":
        os.execvp("uv", ["uv", "run", "--project", repo, "python",
                         os.path.join(repo, "tools", "bench.py"), *args.extra])
    if args.cmd == "install-daemon":
        plist = os.path.join(repo, "launchd", "com.evintunador.ds4-gateway.plist")
        print("The daemon is NOT installed automatically. Preconditions:")
        print("  - `ds4ctl promote` has been run (current symlink exists)")
        print("  - you are confident in the promoted release")
        print("Then run:")
        print(f"  sudo cp {plist} /Library/LaunchDaemons/")
        print("  sudo launchctl bootstrap system /Library/LaunchDaemons/com.evintunador.ds4-gateway.plist")
        print("To remove:")
        print("  sudo launchctl bootout system/com.evintunador.ds4-gateway")
        print("  sudo rm /Library/LaunchDaemons/com.evintunador.ds4-gateway.plist")
        return
    if args.cmd in ("deploy", "promote"):
        extra = ["--promote"] if args.cmd == "promote" else args.extra
        os.execvp("uv", ["uv", "run", "--project", repo, "python",
                         os.path.join(repo, "tools", "deploy.py"), *extra])

    port, status = find_port(args.port)
    if args.cmd == "status":
        print_status(status)
    elif args.cmd == "on":
        print("reloading model (this can take a few minutes)...")
        call(port, "POST", "/admin/on")
        print("model enabled and running")
    elif args.cmd == "off":
        payload = {}
        if args.duration:
            payload["duration_s"] = parse_duration(args.duration)
        r = call(port, "POST", "/admin/off", payload)
        until = r["backend"]["disabled_until"]
        print("model stopped, RAM freed"
              + (f"; auto-relaunch at {time.strftime('%H:%M', time.localtime(until))}"
                 if until else ""))
    elif args.cmd == "swap-model":
        call(port, "POST", "/admin/model_swap")
        print("swap started (config.toml re-read); watching...")
        last = None
        while True:
            time.sleep(2)
            b = call(port, "GET", "/admin/status")["backend"]
            state = b.get("swap_state")
            if state != last and state:
                print(f"  {state}")
                last = state
            if state is None:
                print(f"swap complete; model on :{b['port']} pid {b['pid']}")
                break
            if state.startswith("FAILED"):
                sys.exit(f"swap failed: {state}")
    elif args.cmd == "weights":
        if args.login and args.clear:
            r = call(port, "POST", "/admin/weights", {"login": args.login, "clear": True})
        elif args.login and args.weight is not None:
            r = call(port, "POST", "/admin/weights",
                     {"login": args.login, "weight": args.weight})
        elif args.login:
            sys.exit("usage: ds4ctl weights LOGIN N   (or LOGIN --clear)")
        else:
            r = call(port, "GET", "/admin/weights")
        print(f"default weight: {r['default']}")
        for login, w in sorted(r["weights"].items()):
            mark = "  (runtime override)" if login in r.get("overrides", {}) else ""
            print(f"  {login}: {w}{mark}")
    elif args.cmd == "stats":
        print_stats(status, args.days)


if __name__ == "__main__":
    main()
